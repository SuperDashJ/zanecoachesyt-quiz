# Local development stores leads in data/leads-dev.ndjson automatically.
# For production, configure GitHub-backed storage with a PRIVATE storage repo or
# a dedicated leads branch. Avoid writing live lead data to a public app branch.
#
# Example:
# GITHUB_STORAGE_REPO=SuperDashJ/zanesbestlife-leads
# GITHUB_STORAGE_TOKEN=github_pat_xxx

GITHUB_STORAGE_REPO=
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_BRANCH=leads
GITHUB_STORAGE_COMMITTER_NAME=ZanesBestLife Leads
GITHUB_STORAGE_COMMITTER_EMAIL=

# Transactional email delivery
# Use the verified zanesquiz.com sending domain in production.
RESEND_API_KEY=
RESEND_FROM_EMAIL=ZanesBestLife <results@zanesquiz.com>
RESEND_REPLY_TO=zanesquizresults@gmail.com
